---
import Layout from '../layouts/Layout.astro';

const services = [
  { value: 'roofing',      label: 'Roofing' },
  { value: 'flooring',     label: 'Flooring' },
  { value: 'waterproofing',label: 'Waterproofing' },
  { value: 'painting',     label: 'Painting' },
  { value: 'alterations',  label: 'Alterations' },
  { value: 'restoration',  label: 'Restoration' },
  { value: 'paving',       label: 'Paving' },
  { value: 'other',        label: 'Other' },
];

const urgencyOptions = [
  { value: 'emergency', label: 'Emergency / Immediate' },
  { value: 'weeks',     label: 'Within 2–4 weeks' },
  { value: 'planning',  label: 'Planning phase', checked: true },
];

const steps = [
  {
    num: '1',
    bg: 'bg-brick-red',
    title: 'We Review Your Request',
    body: 'One of our local specialists reviews your project details within 24 business hours.',
  },
  {
    num: '2',
    bg: 'bg-terracotta',
    title: 'We Come to You',
    body: 'We schedule a convenient time to visit your property for a thorough site assessment.',
  },
  {
    num: '3',
    bg: 'bg-sand-stone',
    title: 'You Get a Written Quote',
    body: 'Receive a detailed, transparent quote with clear timelines and fixed pricing.',
  },
];

const inputClass = "w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-lowest text-on-surface font-body-md text-body-md focus:outline-none focus:ring-2 focus:ring-brick-red focus:border-brick-red transition-all";
---

<Layout title="Get a Free Quote | AMATOLA Roof & Floor Restorers" activePage="quote">

  <!-- ── Hero ───────────────────────────────────────────── -->
  <section class="bg-brick-red text-on-primary py-section-gap-mobile md:py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.2) 1px, transparent 0); background-size: 40px 40px;"></div>

    <div class="max-w-container-max mx-auto px-gutter relative z-10 text-center">
      <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg mb-4">
        Get Your Free Quote
      </h1>
      <p class="font-headline-md text-headline-md opacity-90 mb-12">
        No obligation. No hidden costs.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 max-w-4xl mx-auto mt-8">
        {[
          { icon: 'assignment_turned_in', label: 'Free Assessment' },
          { icon: 'description',          label: 'Written Quote'   },
          { icon: 'volunteer_activism',   label: 'No Pressure'     },
        ].map(f => (
          <div class="flex flex-col items-center gap-4">
            <div class="w-16 h-16 rounded-full bg-white/10 flex items-center justify-center border border-white/20">
              <span class="material-symbols-outlined text-3xl">{f.icon}</span>
            </div>
            <h3 class="font-label-md text-label-md uppercase tracking-widest">{f.label}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Form ───────────────────────────────────────────── -->
  <section class="py-section-gap-mobile md:py-section-gap -mt-12 md:-mt-20">
    <div class="max-w-[900px] mx-auto px-gutter">
      <div class="bg-white rounded-xl shadow-xl p-8 md:p-16 border border-terracotta/10">
        <form id="quote-form" class="space-y-10" novalidate>

          <!-- Personal info -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label for="full_name" class="font-label-md text-label-md text-on-surface-variant block">Full Name</label>
              <input id="full_name" name="full_name" type="text" placeholder="John Doe" required class={inputClass} />
            </div>
            <div class="space-y-2">
              <label for="phone" class="font-label-md text-label-md text-on-surface-variant block">Phone Number</label>
              <input id="phone" name="phone" type="tel" placeholder="012 345 6789" required class={inputClass} />
            </div>
            <div class="space-y-2 md:col-span-2">
              <label for="email" class="font-label-md text-label-md text-on-surface-variant block">Email Address</label>
              <input id="email" name="email" type="email" placeholder="john@example.com" required class={inputClass} />
            </div>
            <div class="space-y-2 md:col-span-2">
              <label for="address" class="font-label-md text-label-md text-on-surface-variant block">Property Address</label>
              <input id="address" name="address" type="text" placeholder="123 Street Name, East London, 5201" required class={inputClass} />
            </div>
          </div>

          <!-- Services checkboxes -->
          <div class="space-y-4">
            <p class="font-label-md text-label-md text-on-surface-variant border-b border-outline-variant pb-2">
              Select Required Services
            </p>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
              {services.map(s => (
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input
                    type="checkbox"
                    name="services"
                    value={s.value}
                    class="h-5 w-5 rounded border-outline-variant accent-brick-red cursor-pointer"
                  />
                  <span class="font-body-md text-body-md group-hover:text-brick-red transition-colors">
                    {s.label}
                  </span>
                </label>
              ))}
            </div>
          </div>

          <!-- Urgency radio -->
          <div class="space-y-4">
            <p class="font-label-md text-label-md text-on-surface-variant border-b border-outline-variant pb-2">
              How urgent is this project?
            </p>
            <div class="flex flex-wrap gap-6">
              {urgencyOptions.map(u => (
                <label class="flex items-center gap-3 cursor-pointer">
                  <input
                    type="radio"
                    name="urgency"
                    value={u.value}
                    checked={u.checked ?? false}
                    class="h-5 w-5 border-outline-variant accent-brick-red cursor-pointer"
                  />
                  <span class="font-body-md text-body-md">{u.label}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Description -->
          <div class="space-y-2">
            <label for="description" class="font-label-md text-label-md text-on-surface-variant block">
              Project Description
            </label>
            <textarea
              id="description"
              name="description"
              rows="4"
              placeholder="Please describe the work required…"
              class={inputClass + " resize-none"}
            ></textarea>
          </div>

          <!-- File upload -->
          <div class="space-y-2">
            <p class="font-label-md text-label-md text-on-surface-variant">
              Attach a Photo <span class="opacity-60">(Optional)</span>
            </p>
            <div class="file-drop-zone rounded-xl p-8 text-center">
              <input type="file" id="file_upload" name="photo" accept="image/*" class="hidden" />
              <label for="file_upload" class="cursor-pointer flex flex-col items-center gap-2">
                <span class="material-symbols-outlined text-4xl text-terracotta">add_a_photo</span>
                <span class="font-body-md text-body-md text-on-surface-variant">
                  Click or drag photos here to help us understand your project better.
                </span>
                <span class="font-label-md text-label-md text-outline opacity-70">JPG, PNG up to 10MB</span>
              </label>
            </div>
          </div>

          <!-- Submit -->
          <div class="space-y-4">
            <button
              id="quote-submit"
              type="submit"
              class="w-full bg-brick-red text-on-primary py-4 md:py-5 rounded-lg font-headline-md text-headline-md shadow-lg hover:brightness-110 active:scale-[0.98] transition-all flex items-center justify-center gap-3"
            >
              Request My Free Quote
              <span class="material-symbols-outlined">send</span>
            </button>
            <p class="text-center text-on-surface-variant font-label-md text-label-md opacity-70">
              <span class="material-symbols-outlined text-sm align-middle mr-1">verified_user</span>
              We respect your privacy and will never sell your data.
            </p>
          </div>

        </form>
      </div>
    </div>
  </section>

  <!-- ── What Happens Next ──────────────────────────────── -->
  <section class="bg-deep-earth text-on-primary py-20 overflow-hidden">
    <div class="max-w-container-max mx-auto px-gutter">
      <h2 class="font-headline-lg text-headline-lg text-center mb-16 text-brick-red">
        What Happens Next?
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 relative">
        <!-- Desktop connector line -->
        <div class="hidden md:block absolute top-12 left-[20%] right-[20%] h-px bg-brick-red/30"></div>

        {steps.map(step => (
          <div class="step-card flex flex-col items-center text-center space-y-6 opacity-0 translate-y-8 transition-all duration-700">
            <div class={`w-24 h-24 rounded-2xl ${step.bg} flex items-center justify-center font-display-lg text-display-lg-mobile text-on-primary z-10 shadow-xl`}>
              {step.num}
            </div>
            <div class="space-y-2">
              <h4 class="font-headline-md text-headline-md">{step.title}</h4>
              <p class="font-body-md text-body-md opacity-80 max-w-xs mx-auto">{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Footer band ────────────────────────────────────── -->
  <div class="bg-warm-cream py-12 border-t border-terracotta/20">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="text-center md:text-left space-y-1">
          <p class="font-headline-md text-headline-md text-on-surface">Amatola Roof &amp; Floor Restorers</p>
          <p class="font-body-md text-body-md text-on-surface-variant">— proudly serving Eastern Cape homeowners.</p>
        </div>
        <a
          href="tel:0827842112"
          class="flex items-center gap-3 bg-white/50 border border-terracotta/30 px-8 py-4 rounded-full font-headline-md text-headline-md text-brick-red hover:bg-brick-red hover:text-on-primary transition-all group"
        >
          <span class="material-symbols-outlined group-hover:rotate-12 transition-transform">call</span>
          082 784 2112
        </a>
      </div>
    </div>
  </div>

</Layout>

<script>
  // ── Replace YOUR_FORM_ID with the ID from formspree.io/dashboard ──
  const FORMSPREE_ENDPOINT = 'https://formspree.io/f/YOUR_FORM_ID';

  // ── Form submission ─────────────────────────────────────
  const form = document.getElementById('quote-form') as HTMLFormElement;
  const btn  = document.getElementById('quote-submit') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.innerHTML = '<span class="material-symbols-outlined">sync</span> Sending…';
    btn.classList.add('opacity-80', 'pointer-events-none');

    try {
      const res = await fetch(FORMSPREE_ENDPOINT, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        btn.innerHTML = '✓ Quote Request Received!';
        btn.classList.replace('bg-brick-red', 'bg-tertiary-container');
        setTimeout(() => {
          form.reset();
          btn.innerHTML = 'Request My Free Quote <span class="material-symbols-outlined">send</span>';
          btn.classList.replace('bg-tertiary-container', 'bg-brick-red');
          btn.classList.remove('opacity-80', 'pointer-events-none');
        }, 3000);
      } else {
        throw new Error('Server error');
      }
    } catch {
      btn.innerHTML = 'Failed — please try again';
      btn.classList.replace('bg-brick-red', 'bg-error');
      setTimeout(() => {
        btn.innerHTML = 'Request My Free Quote <span class="material-symbols-outlined">send</span>';
        btn.classList.replace('bg-error', 'bg-brick-red');
        btn.classList.remove('opacity-80', 'pointer-events-none');
      }, 3000);
    }
  });

  // ── Step cards scroll reveal ────────────────────────────
  const cards = document.querySelectorAll<HTMLElement>('.step-card');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            (entry.target as HTMLElement).classList.add('opacity-100', 'translate-y-0');
            (entry.target as HTMLElement).classList.remove('opacity-0', 'translate-y-8');
          }, i * 200);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  cards.forEach(c => observer.observe(c));
</script>
