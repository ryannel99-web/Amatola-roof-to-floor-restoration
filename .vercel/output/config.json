{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/edit/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/new/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/projects/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/projects/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/seed/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/gallery/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}