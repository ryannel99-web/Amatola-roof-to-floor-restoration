# ── Vercel Blob ────────────────────────────────────────────────────────────────
# Generate in your Vercel project dashboard:
# Project → Storage → Blob → Create Store → copy the read/write token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXX

# ── Admin login ────────────────────────────────────────────────────────────────
# The password the client uses to log in to /admin/login
ADMIN_PASSWORD=choose-a-strong-password-here

# ── Session signing ────────────────────────────────────────────────────────────
# A random secret used to sign login cookies — generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-64-char-random-hex-string
